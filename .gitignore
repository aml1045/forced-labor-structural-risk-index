# macOS
.DS_Store

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv*/
venv/
.env
.env.txt

# Site-data reproducer staging output (regenerated by build_site_data.py)
outputs/site_data_staging/

# Generated score artifacts from run.py (regenerated each run; the published site
# build lives under public/data/, not here). The code in outputs/ stays tracked.
outputs/scores.csv
outputs/rankings.csv
outputs/build-notes-*.md
outputs/validation_results*.json
outputs/monte_carlo_results.csv
outputs/monte_carlo_summary.json
# Refresh-stage build artifacts (regenerated per run; shipped provenance lives in
# public/data/ + docs/, not here).
outputs/*.log
outputs/refresh-report-*.md
outputs/build_manifest-*.json
outputs/input-manifest-*.json
outputs/vintage-report-*.md

# Editor / OS cruft
*.swp
*~
.idea/
.vscode/
.claude/

# Stray placeholder stubs
*.txt.bak
*.bak

# Regenerated geospatial intermediates/outputs (rebuilt by build_site_data.py from
# the geolev1 shapefile via build_geojson.py + npx mapshaper + compute_lisa.py).
# Kept out of git: large and fully reproducible. Source code + small inputs stay tracked.
pipeline/6_site_data/**/*.geojson
pipeline/6_site_data/**/*.topojson

# Consolidated external inputs (repo/external) — large / licence-restricted, kept LOCAL only
# (exceed GitHub's 100MB file limit and/or carry redistribution restrictions; see NOTICE).
external/ipums-raw/
external/geo/world_geolev1_2025.*
external/geo/emdat_points_*.geojson

# Raw source inputs (now present locally; large / licence-restricted; connectors regenerate
# data/processed/ from these). Kept LOCAL only — see docs/data-provenance.md to obtain them.
data/raw/
data/aux/worldbank_cache.csv
node_modules/
_refresh-inputs/
pipeline/6_site_data/geospatial/overlay_data.js

# IPUMS-derived aggregate tables + codebook (gated local inputs; IPUMS conditions
# of use -- not redistributed; see docs/REPRODUCING.md)
external/experiments/ipums-signals/*.csv
pipeline/6_site_data/_inputs/ipums-signals/
external/geo/codebook*
